classDiagram
    %% PawPal+ class diagram
    %% Keep this file updated so it matches your final implementation.

    class Owner {
        +str name
        +int available_minutes
        +list~str~ preferences
        +list~Pet~ pets
        +add_pet(pet: Pet) void
    }

    class Pet {
        +str name
        +str species
        +str breed
        +int age
        +list~str~ needs
        +list~Task~ tasks
        +add_task(task: Task) void
    }

    class Task {
        +str name
        +Category category
        +int duration_minutes
        +Priority priority
        +Recurrence recurrence
        +str preferred_time
    }

    class PlanEntry {
        +Task task
        +str start_time
        +str end_time
    }

    class DailyPlan {
        +list~PlanEntry~ entries
        +list~Task~ skipped_tasks
        +int total_minutes
        +str reasoning
        +add_entry(entry: PlanEntry) void
        +summary() str
    }

    class Planner {
        +generate_plan(owner: Owner, pet: Pet, tasks: list~Task~) DailyPlan
        +sort_tasks(tasks: list~Task~) list~Task~
        +explain_reasoning(plan: DailyPlan) str
    }

    class Category {
        <<enumeration>>
        WALK
        FEEDING
        MEDS
        ENRICHMENT
        GROOMING
        OTHER
    }

    class Priority {
        <<enumeration>>
        HIGH
        MEDIUM
        LOW
    }

    class Recurrence {
        <<enumeration>>
        DAILY
        WEEKLY
    }

    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : needs
    Planner ..> Owner : reads constraints
    Planner ..> Task : evaluates
    Planner ..> DailyPlan : produces
    DailyPlan "1" *-- "*" PlanEntry : contains
    PlanEntry --> Task : schedules
    Task --> Category : has
    Task --> Priority : has
    Task --> Recurrence : has
